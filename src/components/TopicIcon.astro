  quant: `<path d="M3 3v18h18"/><path d="M7 14l4-4l3 3l5-6"/>`,
  "vibe-coding": `<path d="M8 8l-4 4l4 4"/><path d="M16 8l4 4l-4 4"/><path d="M14 4l-4 16"/>`,
  english: `<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/>`,
  study: `<path d="M6 4h12a1 1 0 0 1 1 1v15l-7-3l-7 3V5a1 1 0 0 1 1-1z"/><path d="M9 9h6"/>`,
  thought: `<path d="M6 18a5 5 0 1 1 .71-9.95a6 6 0 0 1 11.4 2a4 4 0 0 1-1.11 7.95H6z"/>`,
  book: `<path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0"/><path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0"/><path d="M3 6v13"/><path d="M12 6v13"/><path d="M21 6v13"/>`,
  exhibition: `<rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M3 17l5-5l4 4l3-3l6 6"/>`,
  sport: `<circle cx="17" cy="5" r="2"/><path d="M4 17l5 1l1-1.5"/><path d="M13 20v-4l-4-3l1-6"/><path d="M9 12l3-3l3 3l3 0"/>`,
  doodle: `<path d="M4 20h4l10.5-10.5a2.8 2.8 0 1 0 -4 -4L4 16z"/><path d="M13.5 6.5l4 4"/>`,
  default: `<circle cx="12" cy="12" r="4"/>`,
};

const paths = PATHS[type] ?? PATHS.default;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={paths}
></svg>
